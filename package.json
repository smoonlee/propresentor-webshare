{
  "name": "propresenter-webshare",
  "version": "1.6.3",
  "description": "Screen sharing helper app — serves a live capture for ProPresenter",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "test": "node --test",
    "check": "node --check src/main.js && node --check src/preload.js && node --check src/server.js && node --check src/settings.js && node --check src/encoder.js && node --check src/webview-preload.js && node --check src/fake-fullscreen-code.js && node --check scripts/update-changelog.js && npm test",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable"
  },
  "keywords": [
    "propresenter",
    "webshare",
    "electron",
    "screenshare"
  ],
  "author": "smoonlee",
  "license": "MIT",
  "build": {
    "appId": "com.propresenter.webshare",
    "productName": "ProPresenter WebShare",
    "icon": "assets/webshare-icon.ico",
    "afterPack": "build/afterPack.js",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**"
    ],
    "win": {
      "icon": "assets/webshare-icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ProPresenter WebShare",
      "publisherName": "smoonlee",
      "artifactName": "ProPresenter_WebShare_Setup_${version}.${ext}"
    }
  },
  "engines": {
    "node": ">=26"
  },
  "dependencies": {
    "express": "5.2.1",
    "ffmpeg-static": "^5.3.0",
    "qrcode": "^1.5.4",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "png-to-ico": "3.0.2",
    "sharp": "0.35.3"
  }
}
